# Application
APP_NAME=relivo-be-server
VERSION=0.1.0
ENVIRONMENT=development
HOST=127.0.0.1
PORT=8000
# RELOAD defaults to true in development/local/dev and false otherwise.
# RELOAD=true

# Database (PostgreSQL with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/relivo

# OpenAI
OPENAI_API_KEY=sk-your-key-here
RELIVO_CHAT_MODEL=gpt-5-mini
RELIVO_CHAT_REASONING_EFFORT=low
RELIVO_CHAT_USE_RESPONSES_API=true

# Firecrawl MCP tools for agent web search/scrape/crawl/parse access
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_MCP_ENABLED=true
FIRECRAWL_MCP_URL=https://mcp.firecrawl.dev/v2/mcp

# AWS S3 file storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=relivo.chat
AWS_S3_KEY_PREFIX=user-files
AWS_S3_MAX_UPLOAD_MB=25
AWS_S3_PRESIGNED_EXPIRES_SECONDS=3600
# Optional for S3-compatible providers/local testing.
# AWS_S3_ENDPOINT_URL=http://localhost:9000
# Optional server-side encryption.
# AWS_S3_SERVER_SIDE_ENCRYPTION=AES256
# AWS_S3_KMS_KEY_ID=
